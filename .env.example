DATABASE_URL="postgresql://crescent:change-me@localhost:5432/crescent?schema=public"
POSTGRES_DB=crescent
POSTGRES_USER=crescent
POSTGRES_PASSWORD=change-me

# Bearer token for the legacy /api/ingestion endpoint (n8n / external posters)
INGESTION_API_TOKEN=change-me

# Bearer token for the admin UI (mail account connections, etc.).
# If unset, falls back to INGESTION_API_TOKEN.
ADMIN_API_TOKEN=change-me

# Optional: trust an upstream reverse proxy that authenticates the user and
# forwards an identity header (e.g. Authentik, oauth2-proxy, Tailscale Serve).
# When set, requests that arrive with this header populated are treated as
# admin-authorized without needing ADMIN_API_TOKEN. Leave unset to disable.
# Header name is case-insensitive. Examples:
#   ADMIN_FORWARD_AUTH_HEADER=x-authentik-email
#   ADMIN_FORWARD_AUTH_HEADER=x-forwarded-email
# ADMIN_FORWARD_AUTH_HEADER=

# Optional comma-separated allowlist of accepted values for the header above.
# If empty (and ADMIN_FORWARD_AUTH_HEADER is set), any non-empty value is
# accepted — only safe when the upstream proxy is the ONLY way to reach the app.
# ADMIN_FORWARD_AUTH_ALLOWLIST=alice@example.com,bob@example.com

# Public URL the app is served from. Used to build OAuth redirect URIs.
# This must match a redirect URI registered in your provider's OAuth client.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Token encryption key (32 bytes, base64). Generate with:
#   openssl rand -base64 32
MAIL_ENCRYPTION_KEY=

# Google Cloud OAuth client (Gmail provider).
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${NEXT_PUBLIC_APP_URL}/api/admin/mail/callback/gmail
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Worker poll interval (ms). Default 60000.
# MAIL_POLL_INTERVAL_MS=60000

# Optional: bind address and port for `docker compose up`
# APP_BIND=0.0.0.0
# APP_PORT=3000
